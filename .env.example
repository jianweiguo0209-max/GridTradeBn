# OKX 交易所 API 配置（复制本文件为 .env 并填入真实值）
# .env 文件包含敏感信息，已被 .gitignore 忽略，请勿提交到仓库

# OKX API 密钥
OK_API_KEY=
# OKX API Secret
OK_API_SECRET=
# OKX API 密码（创建 apikey 时设置的 passphrase，不是账号登录密码）
OK_API_PASSWORD=

# 是否模拟盘(demo/simulated-trading)：1=模拟盘，0=实盘。模拟盘密钥必须置 1
OK_SIMULATED=0

# 企业微信机器人 Webhook 地址
WECHAT_WEBHOOK_URL=
