# GridTradeGP 部署配置（复制本文件为 .env 并填入真实值）
# .env 含敏感信息，已被 .gitignore 忽略，请勿提交到仓库。
# 变量与默认值见 gridtrade/config.py::load_deploy_config；非敏感项也在 deploy/fly.toml [env] 配置，
# 敏感项（HL_WALLET_ADDRESS / HL_PRIVATE_KEY / DATABASE_URL）线上走 `fly secrets set`。

# ---- 凭证（敏感，必填）----
# Hyperliquid 钱包地址（主钱包或 API 钱包对应的主账户地址）
HL_WALLET_ADDRESS=
# Hyperliquid 私钥（API 钱包私钥，用于签名下单；切勿泄露）
HL_PRIVATE_KEY=
# 数据库连接串，例：postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=

# ---- 交易所 / 网络 ----
# 交易所标识（当前仅 hyperliquid）
EXCHANGE=hyperliquid
# 是否 testnet：true=测试网，false=主网
HL_TESTNET=false
# 计价/结算币覆写（可选）；留空=用适配器类默认（HL=USDC / OKX=USDT）。
# 仅「同所多结算」场景（如 Binance USDT-M/USDC-M）才需显式设置。
QUOTE_CURRENCY=

# ---- 资金 / 风控 ----
# 单标的名义资金上限（USDC）
CAP=100
# 杠杆倍数
LEVERAGE=5
# 单标的默认资金上限；留空则取 CAP
DEFAULT_CAP=
# 账户总预算（USDC）
TOTAL_BUDGET=1000000
# 最大并发持仓标的数
MAX_CONCURRENT=20

# ---- 运行 / 调度 ----
# monitor 循环间隔（秒）
MONITOR_INTERVAL_SEC=5
# 调度周期（如 12H / 4H / 1H）
SCHEDULER_PERIOD=12H
# 时区偏移（小时），用于整点对齐；东八区=8
UTC_OFFSET=8
# scheduler 启动即跑一次：true=立即跑（调试用），false=睡到整点
SCHEDULER_RUN_ON_START=false

# ---- 标的过滤（逗号分隔，可留空）----
# 黑名单：排除这些标的
BLACKLIST_SYMBOLS=
# 白名单：仅在这些标的中选币（留空=不限制）
UNIVERSE_WHITELIST=

# ---- 测试 ----
# 测试用数据库连接串（pytest 真连 Postgres 时用；留空则跳过相关测试）
TEST_DATABASE_URL=
